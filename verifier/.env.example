# Verifier configuration
PORT=3000
HOST=0.0.0.0

# Ordinals indexer endpoint (ord server or Hiro API)
INDEXER_URL=https://api.hiro.so/ordinals/v1

# Bitcoin network
NETWORK=mainnet

# Session store (memory | redis)
SESSION_STORE=memory

# Optional: Redis URL when SESSION_STORE=redis
# REDIS_URL=redis://localhost:6379

# SSH Agent callback URL (verifier notifies agent on grant/revoke)
SSH_AGENT_URL=http://localhost:3100
