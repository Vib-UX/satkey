# SSH Agent configuration
PORT=3100
HOST=127.0.0.1

# System user SSH keys are managed for
SSH_USER=satkey

# Path to authorized_keys file (default: ~SSH_USER/.ssh/authorized_keys)
# AUTHORIZED_KEYS_PATH=/home/satkey/.ssh/authorized_keys

# Verifier URL for polling ownership changes
VERIFIER_URL=http://localhost:3000

# How often to poll for ownership changes (seconds)
POLL_INTERVAL_SECONDS=30

# Dry-run mode: log changes without writing files
DRY_RUN=false
